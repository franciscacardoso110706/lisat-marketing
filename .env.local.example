# Copia este ficheiro para ".env.local" e preenche com os valores do teu projeto Supabase.
# (Painel Supabase → Project Settings → API)
# Estes valores NÃO são secretos: a "anon key" é pública e a segurança é garantida pelas
# políticas RLS na base de dados.

VITE_SUPABASE_URL=https://o-teu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=a-tua-anon-key
